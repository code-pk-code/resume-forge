# ─────────────────────────────────────────────────────────────────────────────
# ResumeForge — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local overrides.
# On Vercel / Netlify, set these in the dashboard (no file needed).
#
# All variables are optional. Sensible defaults are defined in
# config/app.config.js.  Only set what you want to override.
# ─────────────────────────────────────────────────────────────────────────────

# ── App branding ─────────────────────────────────────────────────────────────
VITE_APP_NAME=ResumeForge
VITE_APP_TAGLINE=Free · A4 · No ads
VITE_APP_DESCRIPTION=Professional resume builder — 9 templates, A4 PDF, free forever.
VITE_SITE_URL=https://your-domain.com
VITE_SUPPORT_EMAIL=
VITE_GITHUB_URL=

# ── Capacity (concurrent users) ───────────────────────────────────────────────
# Max simultaneous active users before "All Workers Busy" screen is shown.
VITE_MAX_WORKERS=10000

# Slot TTL in milliseconds (how long an inactive tab holds a slot).
VITE_SLOT_TTL_MS=55000

# Heartbeat interval in milliseconds (how often an active tab refreshes its slot).
VITE_HEARTBEAT_MS=20000

# localStorage key for slot storage. Change if multiple apps share a domain.
VITE_SLOT_KEY=rf_slots_v4

# ── Resume settings ───────────────────────────────────────────────────────────
# Maximum resume pages before the over-limit warning fires.
VITE_MAX_PAGES=2

# Google Fonts URL. Set to empty string to disable (use system fonts instead).
VITE_FONTS_URL=https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "false" to hide/disable a feature.
VITE_SHOW_CAPACITY_BADGE=true
VITE_SHOW_COLOR_PICKER=true
VITE_SHOW_TEMPLATE_PICKER=true
VITE_SHOW_SECTION_TOGGLES=true
VITE_ENABLE_INTERESTS=true
VITE_ENABLE_VOLUNTEER=true
VITE_ENABLE_SKILL_BARS=true

# ── Defaults (what the app shows on first load) ───────────────────────────────
# Template: nova | executive | carbon | emerald | minimal | creative | tech | diplomat | timeline
VITE_DEFAULT_TEMPLATE=nova

# Comma-separated list of section keys enabled by default.
VITE_DEFAULT_SECTIONS=summary,experience,education,skills,projects,certifications,achievements

# Default accent color (hex). Should match the chosen template.
VITE_DEFAULT_ACCENT=#2D6BE4

# ── Custom accent colors ──────────────────────────────────────────────────────
# Comma-separated hex colors shown in the color picker.
# Leave blank to use the built-in 15-color palette.
VITE_COLOR_PRESETS=
